# Google Gemini API key (free tier: https://aistudio.google.com/apikey).
# The agent uses the native Google Gen AI SDK (langchain-google-genai) on
# gemini-3.5-flash. See FROZEN.md "LLM provider" in the repo root for why.
GEMINI_API_KEY=your-gemini-developer-key

# Vertex/Agent Platform API-key path. Use these when the key belongs to a
# Google Cloud project where the Gemini Developer API is not enabled.
GOOGLE_API_KEY=your-vertex-or-agent-platform-key
GOOGLE_GENAI_USE_VERTEXAI=true

# Optional override. Defaults to gemini-3.5-flash.
# MODEL=gemini-3.5-flash

# Rho Signal Room integrations required for judging with Live A2A on. Missing
# values produce a blocked readiness surface instead of fallback evidence.
# BANKING_A2A_AGENT_URL=http://localhost:9001
# LINKUP_API_KEY=
# REDIS_URL=redis://localhost:6379/0
